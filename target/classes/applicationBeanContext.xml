<?xml version="1.0" encoding="UTF-8"?>


<beans xmlns="http://www.springframework.org/schema/beans"
       xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xsi:schemaLocation="
        http://www.springframework.org/schema/beans
        http://www.springframework.org/schema/beans/spring-beans.xsd">


    <!--bean id="myBean" class="com.example.GreetingService"> </bean>-->

    <bean id="EmailNotificationService" class="com.loose.EmailNotificationService"> </bean>

    <bean id="UserService" class="com.loose.UserService">
        <property name="notificationService" ref="EmailNotificationService"/>

    </bean>

</beans>